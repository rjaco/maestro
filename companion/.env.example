# Maestro Companion — Environment Configuration
# Copy to .env and fill in your values.
# Never commit .env to git.

# === REQUIRED ===

# Anthropic API key (for Claude Code Agent SDK)
ANTHROPIC_API_KEY=

# Telegram bot token (from @BotFather)
MAESTRO_TELEGRAM_TOKEN=

# Allowed Telegram chat IDs (comma-separated)
# Send /chatid to your bot to discover yours
ALLOWED_CHAT_IDS=

# === VOICE (optional) ===

# Groq API key for Whisper STT (free at console.groq.com)
GROQ_API_KEY=

# ElevenLabs API key for TTS (free tier at elevenlabs.io)
ELEVENLABS_API_KEY=

# ElevenLabs voice ID (find in your voices dashboard)
ELEVENLABS_VOICE_ID=

# === PERSONALITY ===

# Personality profile: casual, formal, mentor, peer
MAESTRO_PERSONALITY=casual

# === ADVANCED ===

# Project root (defaults to parent of companion/)
# PROJECT_ROOT=/path/to/your/project

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Claude model for chat mode
CHAT_MODEL=sonnet

# Claude model for build mode
BUILD_MODEL=opus

# Max workers for parallel builds
MAX_WORKERS=3
