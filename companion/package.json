  "description": "Autonomous AI companion — talk to Maestro via Telegram, Slack, or Discord with voice support and persistent personality",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maestro-companion": "./dist/index.js"
  },
  "scripts": {
